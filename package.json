{
  "name": "ai-playwright",
  "version": "1.0.0",
  "description": "AI-powered self-healing Playwright testing framework",
  "main": "ai/runner.js",
  "scripts": {
    "test": "playwright test",

    "test:explore": "playwright test tests/explore.spec.ts --reporter=list",
    "test:users-roles": "playwright test tests/users-roles.spec.ts --reporter=list",
    "test:users-roles:heal": "node ai/users-roles-runner.js",
    "test:api-token": "playwright test tests/api-token.spec.ts --reporter=list",
    "test:api-token:heal": "node ai/api-token-runner.js",
    "test:reports": "playwright test tests/reports.spec.ts --reporter=list",
    "test:reports:heal": "node ai/reports-runner.js",
    "test:merge-reports": "playwright test tests/merge-reports.spec.ts --reporter=list",
    "test:merge-reports:heal": "node ai/merge-reports-runner.js",

    "daily": "playwright test tests/daily/ --workers=4 --reporter=html",
    "daily:heal": "node ai/daily-runner.js",
    "daily:heal:fast": "node ai/daily-runner.js --workers 10",
    "daily:heal:file": "node ai/daily-runner.js --file",
    "daily:heal:dry": "node ai/daily-runner.js --dry-run",
    "daily:chromium": "playwright test tests/daily/ --project=chromium --workers=10 --reporter=html",
    "daily:chrome": "playwright test tests/daily/ --project=chrome --workers=10 --reporter=html",
    "daily:edge": "playwright test tests/daily/ --project=edge --workers=10 --reporter=html",
    "daily:all-browsers": "playwright test tests/daily/ --project=chromium --project=chrome --project=edge --workers=20 --reporter=html",
    "daily:mobile": "playwright test tests/daily/ --project=mobile-chrome --workers=10 --reporter=html",
    "daily:login": "playwright test tests/daily/01-login.spec.ts --reporter=list",
    "daily:viz": "playwright test tests/daily/02-viz.spec.ts --reporter=list",
    "daily:reports": "playwright test tests/daily/03-reports.spec.ts --reporter=list",
    "daily:merge-reports": "playwright test tests/daily/04-merge-reports.spec.ts --reporter=list",
    "daily:shared-resources": "playwright test tests/daily/05-shared-resources.spec.ts --reporter=list",
    "daily:quick-run": "playwright test tests/daily/06-quick-run.spec.ts --reporter=list",
    "daily:masterdata": "playwright test tests/daily/07-masterdata.spec.ts --reporter=list",
    "daily:request": "playwright test tests/daily/08-request.spec.ts --reporter=list",
    "daily:administration": "playwright test tests/daily/09-administration.spec.ts --reporter=list",
    "daily:api-token": "playwright test tests/daily/10-api-token.spec.ts --reporter=list",
    "daily:dynamic-message": "playwright test tests/daily/11-dynamic-message.spec.ts --reporter=list",
    "daily:annotations": "playwright test tests/daily/12-annotations.spec.ts --reporter=list",
    "daily:bursting-group": "playwright test tests/daily/13-report-bursting-group-report.spec.ts --reporter=list",
    "daily:themes": "playwright test tests/daily/14-themes.spec.ts --reporter=list",
    "daily:viz-widgets": "playwright test tests/daily/15-viz-widgets.spec.ts --reporter=list",
    "daily:widget-settings": "playwright test tests/daily/16-widget-settings.spec.ts --reporter=list",
    "daily:viz-widgets-extended": "playwright test tests/daily/17-viz-widgets-extended.spec.ts --reporter=list",

    "ai-run": "node ai/runner.js",
    "crawl": "node ai/crawl.js",
    "generate:explore": "node ai/generateFromCrawl.js",
    "explore": "node ai/explore-runner.js",
    "explore:skip-crawl": "node ai/explore-runner.js --skip-crawl",
    "explore:skip-generate": "node ai/explore-runner.js --skip-generate"
  },
  "dependencies": {
    "@playwright/test": "^1.43.0",
    "axios": "^1.6.8"
  }
}
